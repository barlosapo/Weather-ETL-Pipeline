# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Path to the HTML file WeatherLink generates on your local machine
# Windows example: C:\WeatherLink\output\Current_Vantage_Pro.htm
# Linux/Mac example: /home/user/weatherlink/Current_Vantage_Pro.htm
HTM_PATH=C:\path\to\your\Current_Vantage_Pro.htm

# Supabase project URL — found in Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (safe to use for read/write with RLS enabled)
# Found in Project Settings > API > Project API keys
SUPABASE_KEY=your-anon-key-here
